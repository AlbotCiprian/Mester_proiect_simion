{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(vercel --prod *)",
      "Bash(npx vercel --prod *)",
      "Bash(npx prisma migrate deploy *)",
      "Bash(prisma migrate deploy *)",
      "Bash(rm -rf *)"
    ]
  }
}
